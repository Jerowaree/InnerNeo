---
import {
  getLangFromUrl,
  useTranslations,
  useTranslatedPath,
} from "../i18n/utils";
import { Image } from "astro:assets";
import masterManagerLogo from "../assets/images/logomm.webp";
import nextfitLogo from "../assets/images/nextfit_logo.webp";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const projects = [
  {
    title: t("project1.title"),
    description: t("project1.desc"),
    href: "https://www.mastermanageroficial.com",
    eyebrow: t("project1.eyebrow"),
    metric: t("project1.metric"),
    bullets: [
      t("project1.point1"),
      t("project1.point2"),
      t("project1.point3"),
    ],
    logo: masterManagerLogo,
    logoAlt: "Master Manager",
    cardClass: "lg:col-span-7",
    visualClass:
      "from-[#12071E] via-[#251142] to-[#7B2CBF] shadow-[0_24px_60px_rgba(123,44,191,0.24)]",
    frameClass:
      "bg-white/6 border-white/10 max-w-[430px] px-8 py-6 sm:px-12 sm:py-8",
    logoClass: "w-full h-auto object-contain opacity-95",
    buttonClass:
      "bg-[#612DAA] text-white hover:bg-[#4F2490] hover:shadow-[0_18px_30px_rgba(97,45,170,0.28)]",
  },
  {
    title: t("project2.title"),
    description: t("project2.desc"),
    href: "https://nextfitoficial.com",
    eyebrow: t("project2.eyebrow"),
    metric: t("project2.metric"),
    bullets: [
      t("project2.point1"),
      t("project2.point2"),
      t("project2.point3"),
    ],
    logo: nextfitLogo,
    logoAlt: "NextFit",
    cardClass: "lg:col-span-5",
    visualClass:
      "from-[#040404] via-[#08130B] to-[#0F3E24] shadow-[0_24px_60px_rgba(10,64,32,0.24)]",
    frameClass:
      "bg-black/35 border-white/10 max-w-[430px] px-3 py-3 sm:px-4 sm:py-4",
    logoClass: "w-full h-auto object-contain scale-[1.08]",
    buttonClass:
      "bg-[#67F33D] text-[#07110B] hover:bg-[#7DFF56] hover:shadow-[0_18px_30px_rgba(103,243,61,0.22)]",
  },
];
---

<section class="relative overflow-hidden bg-[#F4F6FB] py-24 sm:py-28" aria-labelledby="projects-title">
  <div class="pointer-events-none absolute inset-0 overflow-hidden">
    <div class="absolute left-[-8rem] top-14 h-64 w-64 rounded-full bg-[#612DAA]/10 blur-3xl"></div>
    <div class="absolute bottom-[-8rem] right-[-4rem] h-72 w-72 rounded-full bg-[#67F33D]/10 blur-3xl"></div>
  </div>

  <div class="relative mx-auto max-w-7xl px-6">
    <div class="mb-14 grid gap-8 lg:grid-cols-[minmax(0,1.1fr)_minmax(340px,0.9fr)] lg:items-end">
      <div class="max-w-3xl">
        <div class="mb-5 inline-flex items-center gap-3 rounded-full border border-[#612DAA]/12 bg-white/80 px-4 py-2 shadow-[0_12px_30px_rgba(15,15,26,0.05)] backdrop-blur">
          <span class="h-2.5 w-2.5 rounded-full bg-[#612DAA]"></span>
          <span class="text-[11px] font-black uppercase tracking-[0.32em] text-[#612DAA]">{t("projects.label")}</span>
        </div>

        <h2
          id="projects-title"
          class="max-w-4xl text-4xl font-mont font-black leading-[0.94] text-[#0F0F1A] sm:text-5xl lg:text-[4.25rem]"
        >
          {t("projects.title").split(" ")[0]}
          <span class="block text-[#612DAA]">{t("projects.title").split(" ").slice(1).join(" ")}</span>
        </h2>
      </div>

      <div class="rounded-[2rem] border border-white/70 bg-white/85 p-6 shadow-[0_18px_45px_rgba(15,15,26,0.06)] backdrop-blur">
        <p class="text-lg leading-relaxed text-[#465065]">
          {t("projects.description")}
        </p>
        <div class="mt-5 flex flex-wrap gap-2">
          <span class="rounded-full border border-[#612DAA]/12 bg-[#612DAA]/6 px-3 py-1 text-xs font-bold uppercase tracking-[0.2em] text-[#612DAA]">
            {t("projects.badge1")}
          </span>
          <span class="rounded-full border border-[#0F0F1A]/8 bg-[#0F0F1A]/4 px-3 py-1 text-xs font-bold uppercase tracking-[0.2em] text-[#0F0F1A]">
            {t("projects.badge2")}
          </span>
          <span class="rounded-full border border-[#0F0F1A]/8 bg-[#0F0F1A]/4 px-3 py-1 text-xs font-bold uppercase tracking-[0.2em] text-[#0F0F1A]">
            {t("projects.badge3")}
          </span>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 gap-8 lg:grid-cols-12">
      {
        projects.map((project, index) => (
          <article
            class:list={[
              "reveal group relative overflow-hidden rounded-[2rem] border border-white/70 bg-white shadow-[0_20px_60px_rgba(15,15,26,0.08)] transition-transform duration-500 hover:-translate-y-1",
              project.cardClass,
              index === 1 && "delay-150",
            ]}
          >
            <div class={`relative overflow-hidden rounded-b-[2rem] bg-gradient-to-br ${project.visualClass}`}>
              <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(255,255,255,0.22),transparent_34%),linear-gradient(180deg,rgba(255,255,255,0.08),rgba(255,255,255,0))]"></div>
              <div class="absolute inset-0 opacity-20 [background-image:linear-gradient(rgba(255,255,255,0.18)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.18)_1px,transparent_1px)] [background-size:30px_30px]"></div>

              <div class="relative z-10 flex min-h-[300px] flex-col justify-between p-6 sm:min-h-[340px] sm:p-8">
                <div class="flex items-start justify-between gap-4">
                  <span class="rounded-full border border-white/16 bg-white/12 px-3 py-1 text-[11px] font-black uppercase tracking-[0.32em] text-white">
                    {project.eyebrow}
                  </span>
                  <span class="rounded-full border border-white/16 bg-black/28 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.22em] text-white">
                    {project.metric}
                  </span>
                </div>

                <div class="relative flex flex-1 items-center justify-center py-8 sm:py-10">
                  <div class={`project-logo-frame w-full rounded-[1.75rem] border backdrop-blur-sm ${project.frameClass}`}>
                    <Image
                      src={project.logo}
                      alt={project.logoAlt}
                      class:list={[
                        "mx-auto block max-h-[180px] w-full drop-shadow-[0_18px_40px_rgba(0,0,0,0.35)] transition-transform duration-700 group-hover:scale-[1.04]",
                        project.logoClass,
                      ]}
                    />
                  </div>
                </div>
              </div>
            </div>

            <div class="p-6 sm:p-8">
              <div class="mb-4 flex items-center justify-between gap-4">
                <span class="text-[11px] font-black uppercase tracking-[0.32em] text-[#8A90A2]">
                  0{index + 1}
                </span>
                <div class="h-px flex-1 bg-gradient-to-r from-[#612DAA]/20 to-transparent"></div>
              </div>

              <h3 class="text-2xl font-black tracking-tight text-[#0F0F1A] sm:text-[2rem]">
                {project.title}
              </h3>

              <p class="mt-4 max-w-2xl text-[15px] leading-7 text-[#596277] sm:text-base">
                {project.description}
              </p>

              <div class="mt-6 flex flex-wrap gap-2">
                {project.bullets.map((bullet) => (
                  <span class="rounded-full border border-[#0F0F1A]/8 bg-[#F6F7FB] px-3 py-1.5 text-xs font-bold uppercase tracking-[0.18em] text-[#394252]">
                    {bullet}
                  </span>
                ))}
              </div>

              <div class="mt-8">
                <a
                  href={project.href}
                  target="_blank"
                  rel="noreferrer"
                  class={`inline-flex items-center gap-3 rounded-full px-5 py-3 text-sm font-black uppercase tracking-[0.2em] transition-all duration-300 ${project.buttonClass}`}
                >
                  {t("project.view")}
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.4"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="transition-transform duration-300 group-hover:translate-x-1"
                  >
                    <path d="M7 17 17 7"></path>
                    <path d="M7 7h10v10"></path>
                  </svg>
                </a>
              </div>
            </div>
          </article>
        ))
      }

      <article class="reveal delay-300 relative overflow-hidden rounded-[2.2rem] border border-[#612DAA]/10 bg-[linear-gradient(135deg,#FFFFFF_0%,#F8F4FF_55%,#EEF8F3_100%)] p-8 text-[#0F0F1A] shadow-[0_24px_70px_rgba(97,45,170,0.12)] lg:col-span-12 lg:p-10">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(97,45,170,0.12),transparent_24%),radial-gradient(circle_at_bottom_right,rgba(103,243,61,0.12),transparent_28%)]"></div>
        <div class="absolute inset-0 opacity-[0.16] [background-image:linear-gradient(rgba(97,45,170,0.12)_1px,transparent_1px),linear-gradient(90deg,rgba(97,45,170,0.12)_1px,transparent_1px)] [background-size:34px_34px]"></div>

        <div class="relative grid gap-8 lg:grid-cols-[minmax(0,1.15fr)_minmax(320px,0.85fr)] lg:items-end">
          <div class="max-w-3xl">
            <span class="inline-flex rounded-full border border-[#612DAA]/12 bg-white/80 px-3 py-1 text-[11px] font-black uppercase tracking-[0.32em] text-[#612DAA]">
              {t("project3.eyebrow")}
            </span>
            <h3 class="mt-5 text-3xl font-black tracking-tight text-[#0F0F1A] sm:text-4xl lg:text-[3.2rem]">
              {t("project3.title")}
            </h3>
            <p class="mt-4 max-w-2xl text-base leading-8 text-[#556074] sm:text-lg">
              {t("project3.desc")}
            </p>
          </div>

          <div class="rounded-[1.8rem] border border-white/80 bg-white/75 p-6 shadow-[0_18px_40px_rgba(15,15,26,0.06)] backdrop-blur-sm">
            <div class="flex flex-wrap gap-2">
              <span class="rounded-full border border-[#612DAA]/10 bg-[#612DAA]/6 px-3 py-1.5 text-xs font-bold uppercase tracking-[0.18em] text-[#612DAA]">
                {t("project3.point1")}
              </span>
              <span class="rounded-full border border-[#612DAA]/10 bg-[#612DAA]/6 px-3 py-1.5 text-xs font-bold uppercase tracking-[0.18em] text-[#612DAA]">
                {t("project3.point2")}
              </span>
              <span class="rounded-full border border-[#612DAA]/10 bg-[#612DAA]/6 px-3 py-1.5 text-xs font-bold uppercase tracking-[0.18em] text-[#612DAA]">
                {t("project3.point3")}
              </span>
            </div>

            <a
              href={translatePath("/contacto")}
              class="mt-8 inline-flex items-center gap-3 rounded-full bg-[#612DAA] px-5 py-3 text-sm font-black uppercase tracking-[0.2em] text-white transition-all duration-300 hover:bg-[#4F2490] hover:shadow-[0_18px_30px_rgba(97,45,170,0.28)]"
            >
              {t("project.start")}
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.4"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M5 12h14"></path>
                <path d="m12 5 7 7-7 7"></path>
              </svg>
            </a>
          </div>
        </div>
      </article>
    </div>
  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("active");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.12 },
    );

    document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
  });
</script>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(28px);
    transition:
      opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .reveal.active {
    opacity: 1;
    transform: translateY(0);
  }

  .delay-150 {
    transition-delay: 0.12s;
  }

  .delay-300 {
    transition-delay: 0.24s;
  }

  .project-logo-frame {
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.12),
      0 24px 60px rgba(0, 0, 0, 0.25);
  }
</style>
