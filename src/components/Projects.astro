---

---

<section class="py-24 bg-white" aria-labelledby="projects-title">
  <div class="max-w-7xl mx-auto px-6">
    <div
      class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-6"
    >
      <div>
        <span
          class="text-[#612DAA] font-bold tracking-widest uppercase text-sm block mb-4"
          >Portafolio</span
        >
        <h2
          id="projects-title"
          class="text-4xl md:text-5xl font-mont font-black text-[#0F0F1A]"
        >
          Nuestros <span class="text-[#612DAA]">Proyectos</span>
        </h2>
      </div>
      <p class="text-gray-500 max-w-md text-lg">
        Software y plataformas de alto rendimiento diseñadas para escalar
        operaciones con tecnología de vanguardia.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 projects-container">
      <!-- Project 1: Scars -->
      <article
        class="reveal group bg-[#F8FAFC] border border-gray-200 rounded-3xl p-8 hover:shadow-2xl hover:shadow-purple-500/10 transition-all duration-500"
      >
        <div class="flex justify-between items-start mb-6">
          <div
            class="w-12 h-12 bg-white rounded-xl shadow-sm flex items-center justify-center group-hover:scale-110 transition-transform overflow-hidden p-1"
          >
            <img
              src="/images/logo_scars.png"
              alt="Scars Logo"
              class="w-full h-full object-contain"
            />
          </div>
        </div>
        <h3
          class="text-xl font-bold text-[#0F0F1A] mb-3 group-hover:text-[#612DAA] transition-colors"
        >
          Scars - Landing & ERP
        </h3>
        <p class="text-gray-600 text-sm leading-relaxed mb-6">
          Desarrollo de landing page corporativa y sistema integral de gestión
          para talleres automotrices, optimizando el control de servicios y
          caja.
        </p>
        <a
          href="https://scarsperu.com"
          target="_blank"
          class="text-sm font-bold text-[#612DAA] flex items-center gap-2 group/link"
        >
          Ver Proyecto
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="3"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="group-hover/link:translate-x-1 transition-transform"
            ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg
          >
        </a>
      </article>

      <!-- Project 2: NextFit -->
      <article
        class="reveal delay-150 group bg-[#F8FAFC] border border-gray-200 rounded-3xl p-8 hover:shadow-2xl hover:shadow-purple-500/10 transition-all duration-500"
      >
        <div class="flex justify-between items-start mb-6">
          <div
            class="w-12 h-12 bg-white rounded-xl shadow-sm flex items-center justify-center group-hover:scale-110 transition-transform overflow-hidden p-1"
          >
            <img
              src="/images/nextfit.jpeg"
              alt="NextFit Logo"
              class="w-full h-full object-contain"
            />
          </div>
        </div>
        <h3
          class="text-xl font-bold text-[#0F0F1A] mb-3 group-hover:text-[#612DAA] transition-colors"
        >
          NextFit - Gestión de Centros Fit
        </h3>
        <p class="text-gray-600 text-sm leading-relaxed mb-6">
          Plataforma integral para la administración inteligente de gimnasios y
          centros deportivos con control de socios y pagos.
        </p>
        <a
          href="https://nextfitoficial.com"
          target="_blank"
          class="text-sm font-bold text-[#612DAA] flex items-center gap-2 group/link"
        >
          Ver Proyecto
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="3"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="group-hover/link:translate-x-1 transition-transform"
            ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg
          >
        </a>
      </article>

      <!-- Project 3: CTA -->
      <article
        class="reveal delay-300 group bg-gradient-to-br from-[#612DAA]/5 to-transparent border border-[#612DAA]/10 rounded-3xl p-8 hover:shadow-2xl hover:shadow-purple-500/10 transition-all duration-500 flex flex-col justify-between"
      >
        <div>
          <div class="flex justify-between items-start mb-6">
            <div
              class="w-12 h-12 bg-white rounded-xl shadow-sm flex items-center justify-center group-hover:scale-110 transition-transform text-[#612DAA] shadow-[0_0_15px_rgba(97,45,170,0.2)]"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M5 12h14"></path><path d="M12 5v14"></path></svg
              >
            </div>
          </div>
          <h3
            class="text-xl font-bold text-[#0F0F1A] mb-3 group-hover:text-[#612DAA] transition-colors"
          >
            ¿Tu Negocio Aquí?
          </h3>
          <p class="text-gray-600 text-sm leading-relaxed mb-6">
            Estamos listos para transformar tu idea en el próximo caso de éxito.
            Tu empresa puede ser la siguiente en dar el salto digital con
            nosotros.
          </p>
        </div>
        <a
          href="/contacto"
          class="text-sm font-bold text-[#612DAA] flex items-center gap-2 group/link"
        >
          Iniciar Proyecto
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="3"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="group-hover/link:translate-x-1 transition-transform"
            ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg
          >
        </a>
      </article>
    </div>
  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("active");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1 },
    );

    document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
  });
</script>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .reveal.active {
    opacity: 1;
    transform: translateY(0);
  }
  .delay-150 {
    transition-delay: 0.15s;
  }
  .delay-300 {
    transition-delay: 0.3s;
  }
</style>
