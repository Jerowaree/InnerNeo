---
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const solutions = [
  {
    name: t('service1.title'),
    href: translatePath('/') + '#services',
    image:
      "https://images.unsplash.com/photo-1512941937669-90a1b58e7e9c?auto=format&fit=crop&q=80&w=400",
    desc: t('service1.desc'),
  },
  {
    name: "E-commerce",
    href: translatePath('/') + '#services',
    image:
      "https://images.unsplash.com/photo-1557821552-17105176677c?auto=format&fit=crop&q=80&w=400",
    desc: t('service1.desc'), // Or use a specific key if available
  },
  {
    name: "Cloud Engineering",
    href: translatePath('/') + '#services',
    image:
      "https://images.unsplash.com/photo-1544197150-b99a580bb7a8?auto=format&fit=crop&q=80&w=400",
    desc: t('service1.desc'),
  },
  {
    name: "Inteligencia Artificial",
    href: translatePath('/') + '#services',
    image:
      "https://images.unsplash.com/photo-1677442136019-21780ecad995?auto=format&fit=crop&q=80&w=400",
    desc: t('service1.desc'),
  },
];

const projects = [
  {
    name: "NextFit",
    href: "https://nextfitoficial.com",
    external: true,
    desc: t('project2.desc'),
  },
  {
    name: "Master Manager",
    href: translatePath('/') + '#projects',
    external: false,
    comingSoon: true,
    desc: t('project3.desc'),
  },
];

const services = [
  {
    name: t('service1.title'),
    href: translatePath('/') + '#services',
    image:
      "https://images.unsplash.com/photo-1553877522-43269d4ea984?auto=format&fit=crop&q=80&w=400",
    desc: t('service1.desc'),
  },
  {
    name: t('service2.title'),
    href: translatePath('/') + '#services',
    image:
      "https://images.unsplash.com/photo-1561070791-2526d30994b5?auto=format&fit=crop&q=80&w=400",
    desc: t('service2.desc'),
  },
  {
    name: t('service3.title'),
    href: translatePath('/') + '#services',
    image:
      "https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&q=80&w=400",
    desc: t('service3.desc'),
  },
  {
    name: t('service4.title'),
    href: translatePath('/') + '#services',
    image:
      "https://images.unsplash.com/photo-1521737604893-d14cc237f11d?auto=format&fit=crop&q=80&w=400",
    desc: t('service4.desc'),
  },
];
---

<nav
  class="fixed top-0 left-0 right-0 z-[100] bg-white/95 backdrop-blur-md border-b border-gray-100 h-[var(--header-height)] flex items-center shadow-sm"
>
  <!-- Scroll Progress Indicator -->
  <div
    id="scroll-progress"
    class="absolute bottom-[-1px] left-0 h-[3.5px] bg-[#612DAA] w-0 transition-all duration-150 ease-out z-[110]"
    style="box-shadow: 0 0 10px rgba(97, 45, 170, 0.4);"
  >
  </div>

  <div class="max-w-7xl mx-auto w-full px-6 flex items-center justify-between">
    <!-- Logo -->
    <a href={translatePath('/')} class="flex items-center gap-2 group shrink-0">
      <span
        class="font-mont text-2xl font-black text-[#0F0F1A] tracking-tighter"
        >INNER<span class="text-[#612DAA]">NEO</span></span
      >
    </a>

    <!-- Nav Content - Pushed to the right -->
    <div class="hidden lg:flex items-center gap-10">
      <div class="flex items-center gap-8">
        <!-- Soluciones Dropdown (Contiene NextFit) -->
        <div class="relative group py-4">
          <button
            class="flex items-center gap-1 text-base font-bold text-[#0F0F1A] hover:text-[#612DAA] transition-colors"
          >
            {t('nav.solutions')}
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="group-hover:rotate-180 transition-transform duration-300"
              ><path d="m6 9 6 6 6-6"></path></svg
            >
          </button>

          <div
            class="absolute top-[100%] left-[-200px] pt-4 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 translate-y-2 group-hover:translate-y-0 z-[110]"
          >
            <div
              class="w-[850px] bg-white border border-gray-100 rounded-[32px] p-6 shadow-2xl overflow-hidden"
            >
              <div class="flex flex-row gap-4">
                {
                  solutions.map((item) => (
                    <a
                      href={item.href}
                      class="flex-1 flex flex-col overflow-hidden transition-all group/item"
                    >
                      <div class="relative h-64 overflow-hidden border border-gray-100 shadow-sm">
                        <!-- Top Purple Line -->
                        <div class="absolute top-0 left-0 right-0 h-[2.5px] bg-[#612DAA] z-20"></div>
                        
                        <img
                          src={item.image}
                          alt={item.name}
                          class="w-full h-full object-cover"
                        />
                        
                        <!-- Title Container (Square) -->
                        <div class="absolute bottom-0 left-0 right-0 bg-white py-3 px-4 z-10 flex items-center min-h-[50px]">
                          <!-- Left Animated Line -->
                          <div class="absolute left-0 top-0 bottom-0 w-[4px] bg-[#612DAA] scale-y-0 group-hover/item:scale-y-100 transition-transform origin-top duration-500"></div>
                          
                          <span class="text-[11px] font-black text-[#0F0F1A] uppercase tracking-wider group-hover/item:text-[#612DAA] transition-colors duration-300">
                            {item.name}
                          </span>
                        </div>
                      </div>
                    </a>
                  ))
                }
              </div>
            </div>
          </div>
        </div>

        <!-- Proyectos Dropdown -->
        <div class="relative group py-4">
          <button
            class="flex items-center gap-1 text-base font-bold text-[#0F0F1A] hover:text-[#612DAA] transition-colors"
          >
            {t('nav.projects')}
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="group-hover:rotate-180 transition-transform duration-300"
              ><path d="m6 9 6 6 6-6"></path></svg
            >
          </button>

          <div
            class="absolute top-[100%] left-[-20px] pt-4 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 translate-y-2 group-hover:translate-y-0 z-[110]"
          >
            <div
              class="w-80 bg-white border border-gray-100 rounded-3xl p-5 shadow-2xl overflow-hidden"
            >
              <span
                class="text-[10px] uppercase tracking-widest font-black text-[#612DAA] px-4 mb-2 block"
                >{t('nav.success_cases')}</span
              >
              <div class="flex flex-col gap-2">
                {
                  projects.map((item) => (
                    <a
                      href={item.href}
                      target={item.external ? "_blank" : undefined}
                      class={`px-4 py-3 rounded-2xl hover:bg-[#F8FAFF] transition-all group/proj flex flex-col ${item.comingSoon ? 'pointer-events-none opacity-80' : ''}`}
                    >
                      <div class="text-sm font-bold text-[#0F0F1A] group-hover/proj:text-[#612DAA] mb-1 flex items-center justify-between">
                        <span class="flex items-center gap-2">
                          {item.name}
                          {item.comingSoon && (
                            <span class="text-[9px] font-black bg-purple-100 text-[#612DAA] px-2 py-0.5 rounded-full uppercase tracking-tighter">
                              {t('nav.coming_soon')}
                            </span>
                          )}
                        </span>
                        {item.external && (
                          <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="14"
                            height="14"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            class="opacity-0 group-hover/proj:opacity-40 transition-opacity"
                          >
                            <path d="M15 3h6v6" />
                            <path d="M10 14 21 3" />
                            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                          </svg>
                        )}
                      </div>
                      <div class="text-[11px] text-[#64748B] leading-snug">
                        {item.desc}
                      </div>
                    </a>
                  ))
                }
              </div>
            </div>
          </div>
        </div>

        <!-- Proceso Link -->
        <a
          href={translatePath('/') + '#process'}
          class="text-base font-bold text-[#0F0F1A] hover:text-[#612DAA] transition-all relative group"
        >
          {t('nav.process')}
          <span
            class="absolute -bottom-1 left-0 w-0 h-0.5 bg-[#612DAA] transition-all group-hover:w-full"
          ></span>
        </a>

        <!-- Servicios Dropdown -->
        <div class="relative group py-4">
          <button
            class="flex items-center gap-1 text-base font-bold text-[#0F0F1A] hover:text-[#612DAA] transition-colors"
          >
            {t('nav.services')}
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="group-hover:rotate-180 transition-transform duration-300"
              ><path d="m6 9 6 6 6-6"></path></svg
            >
          </button>

          <div
            class="absolute top-[100%] right-[-200px] pt-4 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 translate-y-2 group-hover:translate-y-0 z-[110]"
          >
            <div
              class="w-[850px] bg-white border border-gray-100 rounded-[32px] p-6 shadow-2xl overflow-hidden"
            >
              <div class="flex flex-row gap-4">
                {
                  services.map((item) => (
                    <a
                      href={item.href}
                      class="flex-1 flex flex-col overflow-hidden transition-all group/item"
                    >
                      <div class="relative h-64 overflow-hidden border border-gray-100 shadow-sm">
                        <!-- Top Purple Line -->
                        <div class="absolute top-0 left-0 right-0 h-[2.5px] bg-[#612DAA] z-20"></div>
                        
                        <img
                          src={item.image}
                          alt={item.name}
                          class="w-full h-full object-cover"
                        />
                        
                        <!-- Title Container (Square) -->
                        <div class="absolute bottom-0 left-0 right-0 bg-white py-3 px-4 z-10 flex items-center min-h-[50px]">
                          <!-- Left Animated Line -->
                          <div class="absolute left-0 top-0 bottom-0 w-[4px] bg-[#612DAA] scale-y-0 group-hover/item:scale-y-100 transition-transform origin-top duration-500"></div>
                          
                          <span class="text-[11px] font-black text-[#0F0F1A] uppercase tracking-wider group-hover/item:text-[#612DAA] transition-colors duration-300">
                            {item.name}
                          </span>
                        </div>
                      </div>
                    </a>
                  ))
                }
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Contacto & Lang -->
      <div class="bg-transparent pl-4 border-l border-gray-100 flex items-center gap-3">
        <a
          href={translatePath('/contacto')}
          class="inline-flex items-center px-6 py-3 bg-[#612DAA] text-white text-base font-semibold rounded-s-sm hover:shadow-lg hover:shadow-purple-500/30 hover:scale-105 transition-all active:scale-95 uppercase tracking-wide"
        >
          {t('nav.contact')}
        </a>

        <!-- Language Switcher Desktop Dropdown -->
        <div class="relative group hidden lg:block">
          <button
            class="flex items-center gap-1.5 text-xs font-bold text-[#0F0F1A] bg-white border border-gray-200 px-3 py-2 rounded-full shadow-sm hover:border-[#612DAA] hover:text-[#612DAA] transition-all duration-300"
          >
            <!-- Globe Icon -->
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"></path><path d="M2 12h20"></path></svg>
            <span id="current-lang-display" class="tracking-wider uppercase">{lang === 'es' ? t('lang.es') : t('lang.en')}</span>
            <!-- Chevron Down -->
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="group-hover:rotate-180 transition-transform duration-300"
              ><path d="m6 9 6 6 6-6"></path></svg>
          </button>

          <!-- Dropdown Options -->
          <div
            class="absolute top-[100%] right-0 pt-3 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 translate-y-2 group-hover:translate-y-0 z-[110]"
          >
            <div
              class="w-32 bg-white border border-gray-100 rounded-2xl p-2 shadow-xl flex flex-col gap-1"
            >
              <a href={translatePath(Astro.url.pathname, 'es')} class="text-left px-4 py-2 text-sm font-bold text-[#0F0F1A] hover:bg-[#F8FAFF] hover:text-[#612DAA] rounded-xl transition-colors w-full uppercase">{t('lang.es')}</a>
              <a href={translatePath(Astro.url.pathname, 'en')} class="text-left px-4 py-2 text-sm font-bold text-[#0F0F1A] hover:bg-[#F8FAFF] hover:text-[#612DAA] rounded-xl transition-colors w-full uppercase">{t('lang.en')}</a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Mobile Menu Toggle Button -->
    <button id="mobile-menu-btn" class="lg:hidden p-2 text-[#0F0F1A] bg-gray-50 rounded-lg">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="menu-icon"
        ><line x1="4" x2="20" y1="12" y2="12"></line><line
          x1="4"
          x2="20"
          y1="6"
          y2="6"></line><line x1="4" x2="20" y1="18" y2="18"></line></svg
      >
      <svg 
        xmlns="http://www.w3.org/2000/svg" 
        width="24" 
        height="24" 
        viewBox="0 0 24 24" 
        fill="none" 
        stroke="currentColor" 
        stroke-width="2.5" 
        stroke-linecap="round" 
        stroke-linejoin="round" 
        class="close-icon hidden"
        ><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
    </button>
  </div>

  <!-- Mobile Menu Overlay -->
  <div id="mobile-menu-overlay" class="fixed top-[var(--header-height)] left-0 w-full h-[calc(100vh-var(--header-height))] bg-white z-[90] flex-col p-6 pb-32 hidden overflow-y-auto">
    <div class="flex flex-col gap-6 text-xl font-bold mt-4">
      <div class="pb-4 border-b border-gray-100 flex flex-col gap-4">
        <span class="text-[#0F0F1A] opacity-50 text-sm uppercase tracking-widest">{t('nav.solutions')}</span>
        {solutions.map((item) => (
          <a href={item.href} class="text-[#0F0F1A] text-lg pl-2 hover:text-[#612DAA]">{item.name}</a>
        ))}
      </div>
      <div class="pb-4 border-b border-gray-100 flex flex-col gap-4">
        <span class="text-[#0F0F1A] opacity-50 text-sm uppercase tracking-widest">{t('nav.projects')}</span>
        {projects.map((item) => (
          <a href={item.href} class="text-[#0F0F1A] text-lg pl-2 hover:text-[#612DAA] flex items-center gap-2">
            {item.name}
            {item.comingSoon && (
              <span class="text-[9px] font-black bg-purple-100 text-[#612DAA] px-2 py-0.5 rounded-full uppercase tracking-tighter">
                {t('nav.coming_soon')}
              </span>
            )}
          </a>
        ))}
      </div>
      <a href={translatePath('/') + '#process'} class="text-[#0F0F1A] pb-4 border-b border-gray-100 uppercase tracking-wide">{t('nav.process')}</a>
      <a href={translatePath('/') + '#services'} class="text-[#0F0F1A] pb-4 border-b border-gray-100 uppercase tracking-wide">{t('nav.services')}</a>
      
      <!-- Language Switcher Mobile -->
      <div class="flex items-center gap-4 pb-4 border-b border-gray-100 uppercase tracking-wide">
        <span class="text-[#0F0F1A] opacity-50 text-sm">{lang === 'es' ? 'Idioma' : 'Language'}:</span>
        <a href={translatePath(Astro.url.pathname, 'es')} class={`text-[#0F0F1A] hover:text-[#612DAA] font-black ${lang === 'es' ? 'text-[#612DAA]' : ''}`}>{t('lang.es')}</a>
        <span class="text-gray-300">|</span>
        <a href={translatePath(Astro.url.pathname, 'en')} class={`text-[#0F0F1A] hover:text-[#612DAA] font-black ${lang === 'en' ? 'text-[#612DAA]' : ''}`}>{t('lang.en')}</a>
      </div>
      <a href={translatePath('/contacto')} class="text-white bg-[#612DAA] py-4 px-6 rounded-xl text-center uppercase tracking-wider mt-4">{t('nav.contact')}</a>
    </div>
  </div>
</nav>

<script>
  const progressBar = document.getElementById("scroll-progress");

  window.addEventListener("scroll", () => {
    const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
    const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
    const scrolled = (winScroll / height) * 100;

    if (progressBar) {
      progressBar.style.width = scrolled + "%";
    }
  });

  // Mobile Menu Logic
  const mobileMenuBtn = document.getElementById("mobile-menu-btn");
  const mobileMenuOverlay = document.getElementById("mobile-menu-overlay");
  const menuIcon = mobileMenuBtn?.querySelector(".menu-icon");
  const closeIcon = mobileMenuBtn?.querySelector(".close-icon");

  if (mobileMenuBtn && mobileMenuOverlay && menuIcon && closeIcon) {
    mobileMenuBtn.addEventListener("click", () => {
      const isHidden = mobileMenuOverlay.classList.contains("hidden");
      
      if (isHidden) {
        mobileMenuOverlay.classList.remove("hidden");
        mobileMenuOverlay.classList.add("flex");
        document.body.style.overflow = "hidden"; // Prevent background scrolling
        menuIcon.classList.add("hidden");
        closeIcon.classList.remove("hidden");
      } else {
        mobileMenuOverlay.classList.add("hidden");
        mobileMenuOverlay.classList.remove("flex");
        document.body.style.overflow = "";
        menuIcon.classList.remove("hidden");
        closeIcon.classList.add("hidden");
      }
    });

    // Close menu when clicking on a link
    const mobileLinks = mobileMenuOverlay.querySelectorAll("a");
    mobileLinks.forEach(link => {
      link.addEventListener("click", () => {
        mobileMenuOverlay.classList.add("hidden");
        mobileMenuOverlay.classList.remove("flex");
        document.body.style.overflow = "";
        menuIcon.classList.remove("hidden");
        closeIcon.classList.add("hidden");
      });
    });
  }
</script>
