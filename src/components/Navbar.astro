const services = [
  {
    name: "Desarrollo web",
    href: "/#services",
    image:
      "https://images.unsplash.com/photo-1553877522-43269d4ea984?auto=format&fit=crop&q=80&w=400",
    desc: "Desarrollo de software a medida para empresas.",
  },
  {
    name: "Diseño UX/UI",
    href: "/#services",
    image:
      "https://images.unsplash.com/photo-1561070791-2526d30994b5?auto=format&fit=crop&q=80&w=400",
    desc: "Diseño de interfaces intuitivas y atractivas para tus usuarios.",
  },
