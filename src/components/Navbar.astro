    desc: "Desarrollo nativo e híbrido para iOS y Android.",
  },
  {
    name: "E-commerce",
    href: "#",
    image:
      "https://images.unsplash.com/photo-1557821552-17105176677c?auto=format&fit=crop&q=80&w=400",
    desc: "Tiendas online de alto rendimiento y conversión.",
  },
  {
    name: "Cloud Engineering",
    href: "#",
    image:
      "https://images.unsplash.com/photo-1544197150-b99a580bb7a8?auto=format&fit=crop&q=80&w=400",
    desc: "Infraestructura escalable y segura en la nube.",
  },
  {
    name: "Inteligencia Artificial",
    href: "#",
    image:
      "https://images.unsplash.com/photo-1677442136019-21780ecad995?auto=format&fit=crop&q=80&w=400",
    desc: "Modelos predictivos y automatización inteligente.",
