---

---

<section
  id="hero-section"
  class="relative min-h-[90vh] flex items-center pt-[var(--header-height)] overflow-hidden group"
>
  <!-- Dynamic Background with Curve -->
  <div class="absolute inset-0 bg-[#0F0F1A] z-0">
    <div class="absolute inset-0 bg-purple-gradient opacity-90"></div>

    <!-- Mouse Follow Spotlight (Enhanced Visibility) -->
    <div
      id="mouse-spotlight"
      class="pointer-events-none absolute inset-0 z-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300"
      style="background: radial-gradient(800px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), rgba(147, 51, 234, 0.45) 0%, rgba(97, 45, 170, 0.15) 35%, transparent 80%);"
    >
    </div>


    <div class="absolute inset-0 overflow-hidden">
      <!-- Image Container with interactive scale -->
      <div
        class="absolute right-0 top-0 h-full w-full lg:w-[50%] transform group-hover:scale-105 transition-transform duration-[1.5s] ease-out pointer-events-none overflow-hidden"
      >
        <img
          src="/images/herosection.jpg"
          alt="IT Solution Team"
          class="absolute inset-0 h-full w-full object-cover mix-blend-overlay opacity-50 animate-ken-burns"
        />
      </div>
    </div>

    <!-- Deep Pulse Aura (Purple Part) -->
    <div
      class="absolute top-[20%] left-[-10%] w-[60rem] h-[60rem] bg-[#612DAA]/15 rounded-full blur-[150px] animate-pulse-slow"
    >
    </div>



    <!-- Anime.js Particles Layer (Restricted to purple area) -->
    <div 
      id="anime-bg" 
      class="absolute inset-y-0 left-0 w-full lg:w-[60%] z-[2] pointer-events-none opacity-80 overflow-hidden"
      style="mask-image: linear-gradient(to right, black 50%, transparent 95%); -webkit-mask-image: linear-gradient(to right, black 50%, transparent 95%);"
    ></div>

    <!-- Floating Particles/Glows -->
    <div
      class="absolute top-1/4 left-1/4 w-96 h-96 bg-[#612DAA]/30 rounded-full blur-[120px] animate-pulse-slow font-delay-200"
    >
    </div>
    <div
      class="absolute bottom-1/4 right-1/4 w-64 h-64 bg-blue-500/20 rounded-full blur-[100px] animate-pulse-slow font-delay-2000"
    >
    </div>
  </div>



  <!-- Content -->
  <div
    class="relative z-10 max-w-7xl mx-auto px-6 w-full grid lg:grid-cols-2 gap-12 items-center py-12"
  >
    <div class="space-y-8 pt-5">
      <h1
        class="text-5xl md:text-7xl font-mont font-black text-white leading-tight animate-fade-in-up font-delay-200"
      >
        Impulsa tu Negocio <br />
        <span class="relative">
          con <span class="text-white font-black">Soluciones IT</span>
        </span>
      </h1>

      <p
        class="text-gray-100 text-lg md:text-xl max-w-xl leading-relaxed animate-fade-in-up font-delay-400"
      >
        Comprometidos con la entrega de tecnología de vanguardia, priorizamos la
        investigación y el desarrollo como nuestros principales activos.
      </p>

      <div class="flex flex-wrap gap-4 pt-4 animate-fade-in-up font-delay-600">
        <a
          href="#services"
          class="px-8 py-4 bg-white text-[#000000] font-medium rounded-xl shadow-2xl hover:bg-gray-50 transition-all active:scale-95 hover:scale-105"
        >
          Explorar Ahora
        </a>
        <a
          href="#contact"
          class="px-8 py-4 bg-[#612DAA] border-2 border-[#612DAA] text-white font-medium rounded-xl hover:bg-[#6D28D9] hover:border-[#6D28D9] transition-all active:scale-95 flex items-center gap-2 hover:scale-105 shadow-[0_10px_40px_rgba(124,58,237,0.4)]"
        >
          Contáctanos <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="3"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg
          >
        </a>
      </div>
    </div>
  </div>

  <!-- Bottom Curve -->
  <div
    class="absolute bottom-0 left-0 right-0 h-24 bg-white"
    style="clip-path: ellipse(70% 100% at 50% 100%);"
  >
  </div>
</section>

<script>
  import anime from "animejs";

  // Mouse Follow Logic
  const hero = document.getElementById("hero-section");
  const spotlight = document.getElementById("mouse-spotlight");

  if (hero && spotlight) {
    hero.addEventListener("mousemove", (e) => {
      const rect = hero.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;

      spotlight.style.setProperty("--mouse-x", `${x}px`);
      spotlight.style.setProperty("--mouse-y", `${y}px`);
    });
  }

  // Anime.js Particles Logic
  const initParticles = () => {
    const bg = document.getElementById("anime-bg");
    if (!bg) return;
    
    // Clear previous
    bg.innerHTML = '';
    
    const count = 100; // Increased count
    const fragment = document.createDocumentFragment();
    
    for (let i = 0; i < count; i++) {
      const node = document.createElement("div");
      const isWhite = Math.random() > 0.5;
      
      node.style.position = "absolute";
      node.style.backgroundColor = isWhite ? "#FFFFFF" : "#A78BFA";
      node.style.borderRadius = "50%";
      
      const size = Math.random() * 4 + 2; // Size 2px to 6px
      node.style.width = `${size}px`;
      node.style.height = `${size}px`;
      node.style.left = `${Math.random() * 105 - 2.5}%`;
      node.style.top = `${Math.random() * 105 - 2.5}%`;
      node.style.opacity = (Math.random() * 0.7 + 0.3).toString();
      node.style.boxShadow = `0 0 10px ${isWhite ? "rgba(255,255,255,0.8)" : "rgba(167,139,250,0.8)"}`;
      
      fragment.appendChild(node);
    }
    bg.appendChild(fragment);

    anime({
      targets: "#anime-bg div",
      translateX: () => anime.random(-250, 250),
      translateY: () => anime.random(-250, 250),
      scale: () => [anime.random(0.5, 1), anime.random(1, 2.5)],
      opacity: [
        { value: 0.3, duration: 1500, easing: "easeInOutQuad" },
        { value: 0.9, duration: 3000, easing: "easeInOutQuad" },
        { value: 0.3, duration: 1500, easing: "easeInOutQuad" },
      ],
      duration: () => anime.random(6000, 15000),
      delay: () => anime.random(0, 5000),
      direction: "alternate",
      loop: true,
      easing: "easeInOutSine",
    });
  };

  initParticles();
</script>

<style>
  @keyframes ken-burns {
    0%,
    100% {
      transform: scale(1) translate(0, 0);
    }
    50% {
      transform: scale(1.05) translate(-1%, 1%);
    }
  }

  @keyframes image-reveal {
    from {
      opacity: 0;
      transform: translateX(10%) scale(1.05);
    }
    to {
      opacity: 1;
      transform: translateX(0) scale(1);
    }
  }

  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(15px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes pulse-slow {
    0%,
    100% {
      opacity: 0.2;
      transform: scale(1);
    }
    50% {
      opacity: 0.4;
      transform: scale(1.1);
    }
  }

  .animate-ken-burns {
    animation: ken-burns 40s ease-in-out infinite;
  }

  .animate-image-reveal {
    animation: image-reveal 2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .animate-fade-in-up {
    animation: fade-in-up 1.2s cubic-bezier(0.19, 1, 0.22, 1) forwards;
    opacity: 0;
  }

  .animate-pulse-slow {
    animation: pulse-slow 12s ease-in-out infinite;
  }



  .font-delay-200 {
    animation-delay: 0.5s;
  }
  .font-delay-400 {
    animation-delay: 0.8s;
  }
  .font-delay-600 {
    animation-delay: 1.1s;
  }
  .font-delay-2000 {
    animation-delay: 2.5s;
  }
</style>
