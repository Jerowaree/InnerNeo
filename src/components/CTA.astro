---
import ProjectModal from "./ProjectModal.client";
import TypewriterTitle from "./TypewriterTitle.client.tsx";
---

<section id="contact" class="py-32 bg-[#612DAA] relative overflow-hidden group">
  <!-- Animated Background Orbs -->
  <div
    class="absolute top-0 left-0 w-[40rem] h-[40rem] bg-indigo-500/20 rounded-full blur-[100px] -translate-x-1/2 -translate-y-1/2 animate-pulse-slow"
  >
  </div>
  <div
    class="absolute bottom-0 right-0 w-[50rem] h-[50rem] bg-fuchsia-500/20 rounded-full blur-[120px] translate-x-1/4 translate-y-1/4 animate-pulse-slow"
    style="animation-delay: 2s;"
  >
  </div>

  <!-- Subtle Grid Pattern -->
  <div
    class="absolute inset-0 opacity-[0.03] pointer-events-none"
    style="background-image: radial-gradient(white 1px, transparent 1px); background-size: 32px 32px;"
  >
  </div>

  <!-- Floating Tech Symbols (Subtle) -->
  <div
    class="absolute top-20 left-10 text-white/5 font-mono text-6xl font-black pointer-events-none select-none animate-float group-hover:-translate-y-10 group-hover:rotate-12 transition-transform duration-[3s] ease-out"
  >
    {}
  </div>

  <!-- Animated N Decorative Line -->
  <div
    class="absolute inset-0 pointer-events-none z-0 flex items-center justify-center opacity-40"
  >
    <svg
      width="100%"
      height="100%"
      viewBox="0 0 1000 400"
      fill="none"
      preserveAspectRatio="xMidYMid meet"
      class="w-full max-w-6xl"
    >
      <path
        d="M -100 250 C 200 400, 300 0, 600 200 S 900 400, 1100 150"
        stroke="url(#gradient-n-line)"
        stroke-width="3"
        stroke-linecap="round"
        class="animated-n-line"
        pathLength="1"></path>
      <defs>
        <linearGradient id="gradient-n-line" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="rgba(255,255,255,0)"></stop>
          <stop offset="50%" stop-color="rgba(255,255,255,0.7)"></stop>
          <stop offset="100%" stop-color="rgba(255,255,255,0)"></stop>
        </linearGradient>
      </defs>
    </svg>
  </div>

  <div class="max-w-7xl mx-auto px-6 text-center relative z-10">
    <h2
      class="text-4xl md:text-5xl lg:text-6xl font-mont font-black mb-6 leading-tight"
    >
      <TypewriterTitle
        client:load
        text="¿Listo para construir "
        className="text-white inline-block"
      />
      <br class="hidden md:block" />
      <TypewriterTitle
        client:load
        text="algo grande?"
        delay={0.6}
        className="text-transparent bg-clip-text bg-gradient-to-r from-[#A78BFA] to-white inline-block"
      />
    </h2>
    <p
      class="text-white/80 text-lg md:text-xl mb-10 max-w-2xl mx-auto leading-relaxed"
    >
      Cuéntanos tu idea. Nosotros nos encargamos de transformarla en una
      realidad tecnológica de alto impacto.
    </p>
    <div class="flex justify-center w-full mt-4">
      <div class="relative group/btn">
        <!-- Pulsing Aura rings behind button -->
        <div
          class="absolute inset-0 bg-white rounded-xl blur-xl opacity-30 group-hover/btn:opacity-0 transition-all duration-300 animate-pulse-slow"
        >
        </div>

        <!-- Actual Button (Now linking to the new page) -->
        <a
          href="/contacto"
          class="group/btn2 relative px-12 py-5 rounded-xl bg-white border border-transparent hover:bg-transparent hover:border-white text-black hover:text-white font-bold transition-all duration-500 active:scale-95 uppercase tracking-widest text-sm flex items-center justify-center gap-3"
        >
          <!-- Expanding Borders on Hover -->
          <span
            class="absolute inset-0 rounded-xl border-2 border-white opacity-0 scale-100 group-hover/btn2:opacity-40 group-hover/btn2:scale-[1.12] transition-all duration-500 ease-out pointer-events-none z-0"
          ></span>
          <span
            class="absolute inset-0 rounded-xl border border-white opacity-0 scale-100 group-hover/btn2:opacity-10 group-hover/btn2:scale-[1.25] transition-all duration-700 ease-out pointer-events-none z-0"
          ></span>

          <span class="relative z-10 flex items-center gap-2">
            Iniciar un Proyecto
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="group-hover/btn2:translate-x-1 transition-transform"
              ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg
            >
          </span>
        </a>
      </div>
    </div>
  </div>

  <ProjectModal client:load />
</section>

<style>
  @keyframes drawNLine {
    0% {
      stroke-dashoffset: 1;
    }
    45%,
    55% {
      stroke-dashoffset: 0;
    }
    100% {
      stroke-dashoffset: -1;
    }
  }

  .animated-n-line {
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
    animation: drawNLine 6.1s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }
</style>
