---

---

<section class="px-6 py-12">
  <div
    class="max-w-7xl mx-auto rounded-[2rem] bg-[#612DAA] p-8 md:p-12 flex flex-col md:flex-row items-center justify-between gap-8 shadow-2xl"
  >
    <div class="flex items-center gap-6">
      <div
        class="w-16 h-16 bg-white/20 rounded-full flex items-center justify-center text-white"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="32"
          height="32"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path
            d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
          ></path></svg
        >
      </div>
      <div>
        <div
          class="text-white font-medium uppercase tracking-widest text-sm mb-1"
        >
          Llámanos ahora
        </div>
        <div class="text-white text-2xl font-bold">+51 955 730 233</div>
      </div>
    </div>

    <h2
      class="text-2xl md:text-3xl font-mont font-bold text-white max-w-lg text-center md:text-left"
    >
      Mantente conectado con <br /> tecnología de vanguardia
    </h2>

    <div class="relative group/btn">
      <!-- Pulsing Aura rings behind button -->
      <div
        class="absolute inset-0 bg-white rounded-xl blur-xl opacity-30 group-hover/btn:opacity-0 transition-all duration-300 animate-pulse-slow"
      >
      </div>

      <a
        href="#contact"
        class="group/btn2 relative px-8 py-4 bg-white border border-transparent hover:bg-transparent hover:border-white text-black hover:text-white font-bold rounded-xl shadow-xl transition-all duration-500 active:scale-95 flex items-center justify-center gap-3 overflow-visible"
      >
        <!-- Expanding Borders on Hover -->
        <span
          class="absolute inset-0 rounded-xl border-2 border-white opacity-0 scale-100 group-hover/btn2:opacity-40 group-hover/btn2:scale-[1.12] transition-all duration-500 ease-out pointer-events-none z-0"
        ></span>
        <span
          class="absolute inset-0 rounded-xl border border-white opacity-0 scale-100 group-hover/btn2:opacity-10 group-hover/btn2:scale-[1.25] transition-all duration-700 ease-out pointer-events-none z-0"
        ></span>

        <span class="relative z-10 flex items-center gap-2">
          Ponerse en contacto
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="group-hover/btn2:translate-x-1 transition-transform"
            ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg
          >
        </span>
      </a>
    </div>
  </div>
</section>
