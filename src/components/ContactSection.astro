---
import TypewriterTitle from "./TypewriterTitle.client.tsx";
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section
  id="contact"
  class="min-h-screen bg-gray-50 flex items-stretch overflow-hidden"
>
  <div class="flex flex-col lg:flex-row w-full">
    <!-- Left: Content & Branding (Purple) -->
    <div
      class="lg:w-1/2 bg-[#59289e] p-12 md:p-24 flex flex-col justify-center relative"
    >
      <!-- Decorative grid -->
      <div
        class="absolute inset-0 opacity-10 pointer-events-none"
        style="background-image: radial-gradient(#ffffff 1px, transparent 1px); background-size: 30px 30px;"
      >
      </div>

      <div class="relative z-10 max-w-lg">
        <h2
          class="text-5xl md:text-7xl font-mont font-extrabold text-white mb-8 leading-tight"
        >
          <TypewriterTitle client:load text={t('contact.hablemos')} />
          <br />
          <TypewriterTitle
            client:load
            delay={0.4}
            text={t('contact.resultados')}
            className="text-white underline decoration-2 underline-offset-8 inline-block"
          />
        </h2>
        <p class="text-white/80 text-xl leading-relaxed mb-16 font-mont">
          {t('contact.desc')}
        </p>

        <div class="space-y-12">
          <div class="flex items-center gap-6 group">
            <div class="w-1 bg-white h-12 shrink-0"></div>
            <div>
              <p
                class="text-[10px] font-black uppercase tracking-widest text-white/60 mb-1"
              >
                {t('contact.whatsapp')}
              </p>
              <a
                href="tel:+51955730233"
                class="text-xl md:text-2xl font-bold text-white hover:text-white/80 transition-colors tracking-tight"
                >+51 955 730 233</a
              >
            </div>
          </div>
          <div class="flex items-center gap-6 group">
            <div class="w-1 bg-white h-12 shrink-0"></div>
            <div>
              <p
                class="text-[10px] font-black uppercase tracking-widest text-white/60 mb-1"
              >
                {t('contact.email')}
              </p>
              <a
                href="mailto:innerneoficial@gmail.com"
                class="text-xl md:text-2xl font-bold text-white hover:text-white/80 transition-colors tracking-tight break-all md:break-normal"
                >innerneoficial@gmail.com</a
              >
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Right: Form Area (White, Full Height, Sharp Corners) -->
    <div class="lg:w-1/2 bg-white flex flex-col justify-center">
      <div class="p-12 md:p-24 w-full">
        <form
          id="contact-form"
          class="space-y-10 max-w-2xl mx-auto"
          method="POST"
          action={import.meta.env.FORMSPREE_ENDPOINT || "#"}
          data-lang={lang}
        >
          <div class="space-y-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
              <!-- Name -->
              <div class="space-y-2">
                <label
                  for="name"
                  class="text-[10px] font-black uppercase tracking-[0.2em] text-gray-400"
                  >{t('contact.form.name')}</label
                >
                <input
                  type="text"
                  id="name"
                  name="name"
                  placeholder={t('contact.form.placeholder.name')}
                  required
                  class="w-full bg-transparent border-b-2 border-gray-100 py-3 focus:border-purple-500 focus:outline-none transition-colors text-lg text-[#0F0F1A] rounded-none"
                />
              </div>

              <!-- Email -->
              <div class="space-y-2">
                <label
                  for="email"
                  class="text-[10px] font-black uppercase tracking-[0.2em] text-gray-400"
                  >{t('contact.form.email')}</label
                >
                <input
                  type="email"
                  id="email"
                  name="email"
                  placeholder="email@empresa.com"
                  required
                  class="w-full bg-transparent border-b-2 border-gray-100 py-3 focus:border-purple-500 focus:outline-none transition-colors text-lg text-[#0F0F1A] rounded-none"
                />
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
              <!-- Phone -->
              <div class="space-y-2">
                <label
                  for="phone"
                  class="text-[10px] font-black uppercase tracking-[0.2em] text-gray-400"
                  >{t('contact.form.phone')}</label
                >
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  placeholder="+51 955..."
                  class="w-full bg-transparent border-b-2 border-gray-100 py-3 focus:border-purple-500 focus:outline-none transition-colors text-lg text-[#0F0F1A] rounded-none"
                />
              </div>

              <!-- Subject -->
              <div class="space-y-2">
                <label
                  for="subject"
                  class="text-[10px] font-black uppercase tracking-[0.2em] text-gray-400"
                  >{t('contact.form.subject')}</label
                >
                <div class="relative">
                  <select
                    id="subject"
                    name="subject"
                    class="w-full bg-transparent border-b-2 border-gray-100 py-3 focus:border-purple-500 focus:outline-none transition-colors text-lg text-[#0F0F1A] appearance-none rounded-none cursor-pointer"
                  >
                    <option class="px-2" value="new-project"
                      >{t('contact.form.subject.new')}</option
                    >
                    <option class="px-2" value="support">{t('contact.form.subject.support')}</option>
                    <option class="px-2" value="other">{t('contact.form.subject.other')}</option>
                  </select>
                </div>
              </div>
            </div>

            <!-- Message -->
            <div class="space-y-2">
              <label
                for="message"
                class="text-[10px] font-black uppercase tracking-[0.2em] text-gray-400"
                >{t('contact.form.message')}</label
              >
              <textarea
                id="message"
                name="message"
                rows="3"
                placeholder={t('contact.form.placeholder.message')}
                required
                class="w-full bg-transparent border-b-2 border-gray-100 py-3 focus:border-purple-500 focus:outline-none transition-colors text-lg text-[#0F0F1A] resize-none rounded-none"
              ></textarea>
            </div>
          </div>

          <!-- Honeypot -->
          <div style="display: none;" aria-hidden="true">
            <input
              type="text"
              name="website"
              tabindex="-1"
              autocomplete="off"
            />
          </div>

          <!-- Security Layer -->
          <div class="pt-6">
            <div
              class="cf-turnstile"
              data-sitekey={import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ||
                "1x00000000000000000000AA"}
              data-callback="onTurnstileSuccess"
              data-theme="light"
            >
            </div>
          </div>

          <!-- Submit -->
          <button
            type="submit"
            id="submit-btn"
            disabled
            class="w-full py-6 bg-gray-200 text-white font-black uppercase tracking-[0.4em] transition-all cursor-not-allowed group overflow-hidden relative rounded-none"
          >
            <span class="relative z-10">{t('contact.form.submit')}</span>
            <div
              id="btn-bg"
              class="absolute inset-0 bg-[#0F0F1A] opacity-0 transition-opacity duration-300"
            >
            </div>
          </button>

          <p
            id="error-general"
            class="text-red-500 text-xs font-bold text-center hidden"
          >
          </p>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  input,
  textarea,
  select,
  button {
    border-radius: 0 !important;
  }
</style>

<script is:inline>
  // Global callback for Turnstile - available immediately
  window.onTurnstileSuccess = function () {
    const btn = document.getElementById("submit-btn");
    const btnBg = document.getElementById("btn-bg");
    if (btn && btnBg) {
      btn.disabled = false;
      btn.classList.remove("cursor-not-allowed", "bg-gray-200");
      btn.classList.add("text-white", "cursor-pointer");
      btnBg.classList.add("opacity-100");
    }
  };
</script>

<script>
  import { z } from "zod";

  document.addEventListener("DOMContentLoaded", () => {
    const form = document.getElementById("contact-form") as HTMLFormElement;
    if (form) {
      const lang = form.getAttribute("data-lang") || "es";

      const contactSchema = z.object({
        name: z.string().min(2, lang === 'es' ? "El nombre debe tener al menos 2 caracteres" : "Name must be at least 2 characters").max(100, lang === 'es' ? "El nombre es muy largo" : "Name is too long"),
        email: z.string().email(lang === 'es' ? "Por favor ingresa un email válido" : "Please enter a valid email"),
        phone: z.string().optional(),
        subject: z.string().min(1, lang === 'es' ? "Por favor selecciona un área de interés" : "Please select an area of interest"),
        message: z.string().min(10, lang === 'es' ? "El mensaje debe tener al menos 10 caracteres" : "Message must be at least 10 characters").max(1000, lang === 'es' ? "El mensaje es muy largo" : "Message is too long"),
      });

      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());
        const btn = form.querySelector("button");
        const span = btn ? btn.querySelector("span") : null;
        if (!btn || !span) return;

        const originalText = span.innerText;
        const errorGeneral = document.getElementById("error-general");
        
        if (errorGeneral) {
          errorGeneral.classList.add("hidden");
          errorGeneral.textContent = "";
        }

        // Validate using Zod
        try {
          contactSchema.parse(data);
        } catch (error) {
          if (error instanceof z.ZodError) {
            const errorMessages = error.errors.map(err => err.message).join(" • ");
            if (errorGeneral) {
              errorGeneral.textContent = errorMessages;
              errorGeneral.classList.remove("hidden");
            }
          }
          return;
        }

        span.innerText = lang === 'es' ? "Procesando..." : "Processing...";
        btn.disabled = true;

        try {
          // Standard client-side fetch to Formspree
          const response = await fetch(form.action, {
            method: form.method,
            body: formData,
            headers: {
              Accept: "application/json",
            },
          });

          if (response.ok) {
            span.innerText = lang === 'es' ? "¡Enviado!" : "Sent!";
            btn.style.backgroundColor = "#22c55e";
            form.reset();

            if ((window as any).turnstile) {
              (window as any).turnstile.reset();
              btn.disabled = true;
            }

            setTimeout(() => {
              span.innerText = originalText;
              btn.style.backgroundColor = "";
              btn.disabled = false;
            }, 5000);
          } else {
            const respData = await response.json();
            if (errorGeneral) {
              errorGeneral.textContent = respData.errors
                ? respData.errors.map((e: any) => e.message).join(", ")
                : (lang === 'es' ? "Error al enviar el formulario." : "Error sending the form.");
              errorGeneral.classList.remove("hidden");
            }
            span.innerText = originalText;
            btn.disabled = false;
          }
        } catch (err) {
          if (errorGeneral) {
            errorGeneral.textContent = lang === 'es' ? "Error de conexión. Inténtalo de nuevo." : "Connection error. Please try again.";
            errorGeneral.classList.remove("hidden");
          }
          span.innerText = originalText;
          btn.disabled = false;
        }
      });
    }
  });
</script>
