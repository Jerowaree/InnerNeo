---
---

<section
  id="contact"
  class="min-h-screen bg-gray-50 flex items-stretch overflow-hidden"
>
  <div class="flex flex-col lg:flex-row w-full">
    <!-- Left: Content & Branding (Purple) -->
    <div
      class="lg:w-1/2 bg-[#612DAA] p-12 md:p-24 flex flex-col justify-center relative"
    >
      <!-- Decorative grid -->
      <div
        class="absolute inset-0 opacity-10 pointer-events-none"
        style="background-image: radial-gradient(#ffffff 1px, transparent 1px); background-size: 30px 30px;"
      >
      </div>

      <div class="relative z-10 max-w-lg">
        <h2
          class="text-5xl md:text-7xl font-syne font-bold text-white mb-8 leading-tight"
        >
          Hablemos de <br />
          <span class="text-white underline decoration-2 underline-offset-8"
            >Resultados.</span
          >
        </h2>
        <p class="text-white/80 text-xl leading-relaxed mb-16">
          Estamos listos para procesar tu solicitud con los más altos estándares
          de ingeniería.
        </p>

        <div class="space-y-12">
          <div class="flex items-center gap-6 group">
            <div class="w-1 bg-white h-12"></div>
            <div>
              <p
                class="text-[10px] font-black uppercase tracking-widest text-white/60 mb-1"
              >
                WhatsApp / Call
              </p>
              <a
                href="tel:+51955730233"
                class="text-2xl font-bold text-white hover:text-white/80 transition-colors tracking-tight"
                >+51 955 730 233</a
              >
            </div>
          </div>
          <div class="flex items-center gap-6 group">
            <div class="w-1 bg-white h-12"></div>
            <div>
              <p
                class="text-[10px] font-black uppercase tracking-widest text-white/60 mb-1"
              >
                Email Oficial
              </p>
              <a
                href="mailto:innerneoficial@gmail.com"
                class="text-2xl font-bold text-white hover:text-white/80 transition-colors tracking-tight"
                >innerneoficial@gmail.com</a
              >
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Right: Form Area (White, Full Height, Sharp Corners) -->
    <div class="lg:w-1/2 bg-white flex flex-col justify-center">
      <div class="p-12 md:p-24 w-full">
        <form
          id="contact-form"
          class="space-y-10 max-w-2xl mx-auto"
          method="POST"
          action={import.meta.env.FORMSPREE_ENDPOINT || "#"}
        >
          <div class="space-y-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
              <!-- Name -->
              <div class="space-y-2">
                <label
                  for="name"
                  class="text-[10px] font-black uppercase tracking-[0.2em] text-gray-400"
                  >Nombre o Razón Social*</label
                >
                <input
                  type="text"
                  id="name"
                  name="name"
                  placeholder="Tu nombre"
                  required
                  class="w-full bg-transparent border-b-2 border-gray-100 py-3 focus:border-purple-500 focus:outline-none transition-colors text-lg text-[#0F0F1A] rounded-none"
                />
              </div>

              <!-- Email -->
              <div class="space-y-2">
                <label
                  for="email"
                  class="text-[10px] font-black uppercase tracking-[0.2em] text-gray-400"
                  >Email*</label
                >
                <input
                  type="email"
                  id="email"
                  name="email"
                  placeholder="email@empresa.com"
                  required
                  class="w-full bg-transparent border-b-2 border-gray-100 py-3 focus:border-purple-500 focus:outline-none transition-colors text-lg text-[#0F0F1A] rounded-none"
                />
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
              <!-- Phone -->
              <div class="space-y-2">
                <label
                  for="phone"
                  class="text-[10px] font-black uppercase tracking-[0.2em] text-gray-400"
                  >Teléfono / WhatsApp</label
                >
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  placeholder="+51 955..."
                  class="w-full bg-transparent border-b-2 border-gray-100 py-3 focus:border-purple-500 focus:outline-none transition-colors text-lg text-[#0F0F1A] rounded-none"
                />
              </div>

              <!-- Subject -->
              <div class="space-y-2">
                <label
                  for="subject"
                  class="text-[10px] font-black uppercase tracking-[0.2em] text-gray-400"
                  >Área de Interés</label
                >
                <div class="relative">
                  <select
                    id="subject"
                    name="subject"
                    class="w-full bg-transparent border-b-2 border-gray-100 py-3 focus:border-purple-500 focus:outline-none transition-colors text-lg text-[#0F0F1A] appearance-none rounded-none cursor-pointer"
                  >
                    <option class="px-2" value="new-project"
                      >Nuevo Proyecto</option
                    >
                    <option class="px-2" value="partnership">Alianza</option>
                    <option class="px-2" value="support">Soporte</option>
                    <option class="px-2" value="other">Otro</option>
                  </select>
                </div>
              </div>
            </div>

            <!-- Message -->
            <div class="space-y-2">
              <label
                for="message"
                class="text-[10px] font-black uppercase tracking-[0.2em] text-gray-400"
                >Tu Mensaje *</label
              >
              <textarea
                id="message"
                name="message"
                rows="3"
                placeholder="Escribe tu mensaje..."
                required
                class="w-full bg-transparent border-b-2 border-gray-100 py-3 focus:border-purple-500 focus:outline-none transition-colors text-lg text-[#0F0F1A] resize-none rounded-none"
              ></textarea>
            </div>
          </div>

          <!-- Honeypot -->
          <div style="display: none;" aria-hidden="true">
            <input
              type="text"
              name="website"
              tabindex="-1"
              autocomplete="off"
            />
          </div>

          <!-- Security Layer -->
          <div class="pt-6">
            <div
              class="cf-turnstile"
              data-sitekey={import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ||
                "1x00000000000000000000AA"}
              data-callback="onTurnstileSuccess"
              data-theme="light"
            >
            </div>
          </div>

          <!-- Submit -->
          <button
            type="submit"
            id="submit-btn"
            disabled
            class="w-full py-6 bg-gray-200 text-white font-black uppercase tracking-[0.4em] transition-all cursor-not-allowed group overflow-hidden relative rounded-none"
          >
            <span class="relative z-10">Enviar Consulta</span>
            <div
              id="btn-bg"
              class="absolute inset-0 bg-[#0F0F1A] opacity-0 transition-opacity duration-300"
            >
            </div>
          </button>

          <p
            id="error-general"
            class="text-red-500 text-xs font-bold text-center hidden"
          >
          </p>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  input,
  textarea,
  select,
  button {
    border-radius: 0 !important;
  }
</style>

<script is:inline>
  // Global callback for Turnstile - available immediately
  window.onTurnstileSuccess = function() {
    const btn = document.getElementById("submit-btn");
    const btnBg = document.getElementById("btn-bg");
    if (btn && btnBg) {
      btn.disabled = false;
      btn.classList.remove("cursor-not-allowed", "bg-gray-200");
      btn.classList.add("text-white", "cursor-pointer");
      btnBg.classList.add("opacity-100");
    }
  };
</script>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const form = document.getElementById("contact-form") as HTMLFormElement;
    if (form) {
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const formData = new FormData(form);
        const btn = form.querySelector("button");
        const span = btn ? btn.querySelector("span") : null;
        if (!btn || !span) return;

        const originalText = span.innerText;
        span.innerText = "Procesando...";
        btn.disabled = true;

        const errorGeneral = document.getElementById("error-general");
        if (errorGeneral) errorGeneral.classList.add("hidden");

        try {
          // Standard client-side fetch to Formspree
          const response = await fetch(form.action, {
            method: form.method,
            body: formData,
            headers: {
              'Accept': 'application/json'
            }
          });

          if (response.ok) {
            span.innerText = "¡Enviado!";
            btn.style.backgroundColor = "#22c55e";
            form.reset();

            if ((window as any).turnstile) {
              (window as any).turnstile.reset();
              btn.disabled = true;
            }

            setTimeout(() => {
              span.innerText = originalText;
              btn.style.backgroundColor = "";
              btn.disabled = false;
            }, 5000);
          } else {
            const data = await response.json();
            if (errorGeneral) {
              errorGeneral.textContent = data.errors ? data.errors.map((e: any) => e.message).join(", ") : "Error al enviar el formulario.";
              errorGeneral.classList.remove("hidden");
            }
            span.innerText = originalText;
            btn.disabled = false;
          }
        } catch (err) {
          if (errorGeneral) {
            errorGeneral.textContent = "Error de conexión. Inténtalo de nuevo.";
            errorGeneral.classList.remove("hidden");
          }
          span.innerText = originalText;
          btn.disabled = false;
        }
      });
    }
  });
</script>
