---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const steps = [
  {
    title: t('process.step1.title'),
    desc: t('process.step1.desc'),
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>`
  },
  {
    title: t('process.step2.title'),
    desc: t('process.step2.desc'),
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>`
  },
  {
    title: t('process.step3.title'),
    desc: t('process.step3.desc'),
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`
  },
  {
    title: t('process.step4.title'),
    desc: t('process.step4.desc'),
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55.45 1 1 1h2c.55 0 1-.45 1-1v-2.34"/><path d="M12 2v12.66"/><path d="M12 2H7.5c-1 0-1.5.5-1.5 1.5v4c0 1 .5 1.5 1.5 1.5h9c1 0 1.5-.5 1.5-1.5v-4C18 2.5 17.5 2 16.5 2H12z"/></svg>`
  }
];
---

<section id="process" class="py-24 bg-[#1E1E1E] relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="text-center mb-24 flex flex-col items-center">
      <span class="text-[#612DAA] font-bold tracking-widest uppercase text-sm block mb-4">{t('process.label')}</span>
      <h2 class="text-4xl md:text-5xl font-mont font-black text-white mb-6">
        <Fragment set:html={t('process.title')} />
      </h2>
      <!-- Loop Progress Bar -->
      <div class="w-32 h-1.5 bg-white/10 rounded-full overflow-hidden relative">
        <div class="absolute top-0 left-0 h-full w-1/3 bg-[#612DAA] rounded-full animated-progress-bar"></div>
      </div>
    </div>

    <div class="relative">
      <!-- Interconnected Zigzag Line (Desktop) -->
      <div class="hidden lg:block absolute inset-0 z-0">
        <svg width="100%" height="100%" viewBox="0 0 1200 400" fill="none" preserveAspectRatio="none" class="opacity-30">
          <path
            id="zigzag-path"
            d="M 150 150 L 450 310 L 750 110 L 1050 310"
            stroke="#612DAA"
            stroke-width="3"
            stroke-dasharray="1"
            stroke-dashoffset="1"
            pathLength="1"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-dasharray="8 8"
            class="transition-all duration-[2000ms] ease-in-out"
          />
        </svg>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8 relative z-10">
        {steps.map((step, idx) => (
          <div class={`group text-center process-step opacity-0 translate-y-12 transition-all duration-700 ease-out ${idx === 1 ? 'lg:mt-32' : idx === 2 ? 'lg:-mt-8' : idx === 3 ? 'lg:mt-32' : ''}`}>
            <div class="relative mb-8 flex justify-center">
              <div class={`w-20 h-20 ${idx % 2 === 0 ? 'bg-[#612DAA] text-white' : 'bg-white text-[#0F0F1A]'} rounded-2xl flex items-center justify-center shadow-2xl group-hover:scale-110 ${idx % 2 === 0 ? 'group-hover:rotate-3' : 'group-hover:-rotate-3'} transition-all duration-500`}>
                <Fragment set:html={step.icon} />
              </div>
            </div>
            <h3 class="text-xl font-bold text-white mb-3">{step.title}</h3>
            <p class="text-gray-400 text-sm leading-relaxed max-w-[220px] mx-auto">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          // Animate the zigzag line tracing across the steps
          const path = entry.target.querySelector('#zigzag-path');
          if (path) {
            (path as SVGPathElement).style.strokeDashoffset = '0';
          }
          
          // Animate the cards popping up sequentially
          const steps = entry.target.querySelectorAll('.process-step');
          steps.forEach((step, index) => {
            setTimeout(() => {
              step.classList.remove('opacity-0', 'translate-y-12');
              step.classList.add('opacity-100', 'translate-y-0');
            }, index * 250); 
          });
          
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.2 });

    const processSection = document.getElementById('process');
    if (processSection) observer.observe(processSection);
  });
</script>

<style>
  @keyframes progressLoop {
    0% {
      transform: translateX(-100%);
    }
    100% {
      transform: translateX(300%);
    }
  }

  .animated-progress-bar {
    animation: progressLoop 2s ease-in-out infinite;
  }
</style>
