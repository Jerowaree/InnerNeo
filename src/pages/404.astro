---
// This is the custom 404 page that Astro generates as 404.html.
// Netlify will automatically serve this for any unknown route.
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Página no encontrada | Innerneo Labs</title>
  <!-- Redirect immediately to home -->
  <meta http-equiv="refresh" content="0;url=/" />
  <style>
    body {
      background-color: #0F0F1A;
      color: #ffffff;
      font-family: 'Montserrat', system-ui, sans-serif;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 100vh;
      margin: 0;
      text-align: center;
    }
    .loader {
      border: 4px solid rgba(167, 139, 250, 0.2);
      border-top: 4px solid #612DAA;
      border-radius: 50%;
      width: 48px;
      height: 48px;
      animation: spin 1s linear infinite;
      margin-bottom: 24px;
    }
    @keyframes spin {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }
  </style>
</head>
<body>
  <div class="loader"></div>
  <h2>Redireccionando al inicio...</h2>
  <p style="color: #64748B; margin-top: 12px;">La página que buscas no existe o fue movida.</p>

  <script>
    // Fallback JavaScript redirect
    window.location.replace("/");
  </script>
</body>
</html>
