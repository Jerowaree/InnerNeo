---
import Navbar from "../../../components/Navbar.astro";
import ContactSection from "../../../components/ContactSection.astro";
import Footer from "../../../components/Footer.astro";
import { getLangFromUrl, useTranslations } from "../../../i18n/utils";
import KeywordMarquee from "../../../components/KeywordMarquee.astro";
import Layout from "../../../layouts/Layout.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer
></script>

<Layout
  title={t("meta.contact.title")}
  description={t("meta.contact.desc")}
  image="/images/contactus.jpg"
>
  <Navbar />
  <main class="pt-20">
    <div
      class="h-[400px] relative overflow-hidden flex items-center justify-center"
    >
      <!-- Background Image -->
      <img
        src="/images/contactus.jpg"
        alt="Contact Us"
        class="absolute inset-0 w-full h-full object-cover"
      />
      <!-- Overlay for better contrast -->
      <div class="absolute inset-0 bg-black/80 z-10"></div>

      <div class="relative z-20 max-w-4xl mx-auto px-6 text-center">
        <h1
          class="text-4xl uppercase md:text-8xl font-mont font-extrabold text-white mb-6 tracking-tight"
        >
          <Fragment set:html={t("contact.title")} />
        </h1>
        <p class="text-gray-200 text-lg md:text-xl font-medium">
          {t("contact.subtitle")}
        </p>
      </div>
    </div>
    <ContactSection />

    <!-- FAQ / Next Steps Section -->
    <section class="py-24 bg-gray-50/50">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
          <!-- Column 1: FAQ -->
          <div class="lg:col-span-2 space-y-8">
            <h3 class="text-3xl font-syne font-bold text-[#0F0F1A]">
              {t("contact.faq.title")}
            </h3>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
              <div class="space-y-3">
                <h4 class="font-bold text-[#612DAA]">
                  {t("contact.faq.q1")}
                </h4>
                <p class="text-gray-500 text-sm leading-relaxed">
                  {t("contact.faq.a1")}
                </p>
              </div>
              <div class="space-y-3">
                <h4 class="font-bold text-[#612DAA]">
                  {t("contact.faq.q2")}
                </h4>
                <p class="text-gray-500 text-sm leading-relaxed">
                  {t("contact.faq.a2")}
                </p>
              </div>
              <div class="space-y-3">
                <h4 class="font-bold text-[#612DAA]">
                  {t("contact.faq.q3")}
                </h4>
                <p class="text-gray-500 text-sm leading-relaxed">
                  {t("contact.faq.a3")}
                </p>
              </div>
              <div class="space-y-3">
                <h4 class="font-bold text-[#612DAA]">
                  {t("contact.faq.q4")}
                </h4>
                <p class="text-gray-500 text-sm leading-relaxed">
                  {t("contact.faq.a4")}
                </p>
              </div>
            </div>
          </div>

          <!-- Column 2: Process Steps -->
          <div
            class="bg-white p-8 rounded-[2rem] border border-gray-100 shadow-xl shadow-purple-500/5"
          >
            <h3 class="text-xl font-bold text-[#0F0F1A] mb-8">
              {t("contact.next.title")}
            </h3>
            <ul class="space-y-6">
              <li class="flex gap-4">
                <div
                  class="w-8 h-8 rounded-full bg-purple-100 text-[#612DAA] flex items-center justify-center font-bold text-sm shrink-0"
                >
                  1
                </div>
                <div>
                  <h5 class="font-bold text-sm">
                    {t("contact.next.step1.title")}
                  </h5>
                  <p class="text-xs text-gray-500 mt-1">
                    {t("contact.next.step1.desc")}
                  </p>
                </div>
              </li>
              <li class="flex gap-4">
                <div
                  class="w-8 h-8 rounded-full bg-purple-100 text-[#612DAA] flex items-center justify-center font-bold text-sm shrink-0"
                >
                  2
                </div>
                <div>
                  <h5 class="font-bold text-sm">
                    {t("contact.next.step2.title")}
                  </h5>
                  <p class="text-xs text-gray-500 mt-1">
                    {t("contact.next.step2.desc")}
                  </p>
                </div>
              </li>
              <li class="flex gap-4">
                <div
                  class="w-8 h-8 rounded-full bg-purple-100 text-[#612DAA] flex items-center justify-center font-bold text-sm shrink-0"
                >
                  3
                </div>
                <div>
                  <h5 class="font-bold text-sm">
                    {t("contact.next.step3.title")}
                  </h5>
                  <p class="text-xs text-gray-500 mt-1">
                    {t("contact.next.step3.desc")}
                  </p>
                </div>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
