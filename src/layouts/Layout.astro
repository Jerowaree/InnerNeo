---
import "@fontsource/dm-mono/400.css";
import "@fontsource/kumbh-sans/400.css";
import "@fontsource/kumbh-sans/700.css";
import "@fontsource/kumbh-sans/900.css";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "InnerNeo Labs — Donde las ideas se convierten en sistemas",
  description = "Agencia de desarrollo e innovación especializada en desarrollo web, desarrollo mobile, software a medida, diseño UX/UI, marketing digital, campañas digitales y soluciones IT escalables.",
  image = "/images/innerneologo.jpeg",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url).href;
const socialImageURL = new URL(image, Astro.site ?? Astro.url).href;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/jpeg" href="/images/innerneologo.jpeg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta
      name="keywords"
      content="desarrollo de software a medida, desarrollo web, aplicaciones web, desarrollo mobile, diseño UX/UI, ingeniería digital, marketing digital, campañas digitales, innerneo labs, soluciones it, sistemas escalables, MVP para startups, software factory, consultoría tecnológica, transformación digital"
    />
    <meta name="author" content="Innerneo Labs" />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageURL} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={socialImageURL} />
  </head>
  <body
    class="antialiased font-sans bg-[color:var(--bg-base)] text-[color:var(--text-primary)]"
  >
    <slot />
    
    <!-- Hidden Google Translate Container -->
    <div id="google_translate_element" style="display: none;"></div>

    <script type="text/javascript">
      function googleTranslateElementInit() {
        new google.translate.TranslateElement({
          pageLanguage: 'es', 
          includedLanguages: 'es,en', 
          autoDisplay: false
        }, 'google_translate_element');
      }
    </script>
    <script type="text/javascript" src="https://translate.googleapis.com/translate_a/element.js?cb=googleTranslateElementInit"></script>

    <!-- Easter Egg for Developers -->
    <script>
      console.log(
        "%c INNERNEO LABS %c \n\n¡Hola! Si estás leyendo esto, es porque te gusta ver cómo están construidas las cosas.\nSi te apasiona el código limpio, el rendimiento y quieres construir algo increíble o unirte a nosotros, hablemos.\n -> innerneoficial@gmail.com\n\n",
        "background: #612DAA; color: #FFFFFF; padding: 6px 12px; border-radius: 6px; font-weight: bold; font-size: 14px; letter-spacing: 2px;",
        "color: #A78BFA; font-size: 14px; font-family: monospace;",
      );
    </script>
  </body>
</html>

<style is:global>
  /* preserve minimal reset from original layout */
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
  
  /* Hide Google Translate completely */
  .skiptranslate, .goog-te-banner-frame {
    display: none !important;
  }
  body {
    top: 0px !important;
  }
</style>
