---
import "@fontsource/dm-mono/400.css";
import "@fontsource/kumbh-sans/400.css";
import "@fontsource/kumbh-sans/700.css";
import "@fontsource/kumbh-sans/900.css";
import "../styles/global.css";
import { getLangFromUrl, useTranslations } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "InnerNeo Labs — Donde las ideas se convierten en sistemas",
  description = "Agencia de desarrollo e innovación especializada en desarrollo web, desarrollo mobile, software a medida, diseño UX/UI, marketing digital, campañas digitales y soluciones IT escalables.",
  image = "/images/innerneologo.jpeg",
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url).href;
const socialImageURL = new URL(image, Astro.site ?? Astro.url).href;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/jpeg" href="/images/innerneologo.jpeg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="google-site-verification" content="_wSfK6RF81C877rvdtsGwqCaZdFiFZDIbv6PLL9U4ms" />

    <!-- Optimized Google Fonts with preload -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Kumbh+Sans:ital,wght@0,400;0,700;0,900&display=swap" rel="stylesheet">

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta
      name="keywords"
      content="desarrollo de software a medida, desarrollo web, aplicaciones web, desarrollo mobile, diseño UX/UI, ingeniería digital, marketing digital, campañas digitales, innerneo labs, soluciones it, sistemas escalables, MVP para startups, software factory, consultoría tecnológica, transformación digital"
    />
    <meta name="author" content="Innerneo Labs" />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageURL} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={socialImageURL} />
  </head>
  <body
    class="antialiased font-sans bg-[color:var(--bg-base)] text-[color:var(--text-primary)]"
  >
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[200] focus:px-4 focus:py-2 focus:bg-white focus:text-[#612DAA] focus:rounded-lg focus:shadow-xl focus:font-bold focus:outline-none focus:ring-2 focus:ring-[#612DAA]"
    >
      {t('a11y.skipLink')}
    </a>
    <slot />
    
    <!-- Easter Egg for Developers -->
    <script>
    </script>
  </body>
</html>

<style is:global>
  /* preserve minimal reset from original layout */
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
